# ---------------------------------------------------------------------------
# Antidote
source $(brew --prefix)/opt/antidote/share/antidote/antidote.zsh
antidote load

# ---------------------------------------------------------------------------
# Startship Prompt
eval "$(starship init zsh)"

# ---------------------------------------------------------------------------
# FNM (replacement of NVM)
export FNM_COREPACK_ENABLED=true
eval "$(fnm env --use-on-cd)"

# ---------------------------------------------------------------------------
# Aliases

alias p=pnpm
alias pa='pnpm add'
alias pad='pnpm add -D'
alias pb='pnpm build'
alias pd='pnpm dev'
alias pin='pnpm install'
alias pln='pnpm lint'
alias pui='pnpm up -i -L'
alias prm='pnpm remove'
alias px='pnpm dlx'
alias pt='pnpm test'
alias ptc='pnpm test --coverage'
alias pp='pnpm why'

alias ls="lsd --group-dirs=first"
alias ll="ls -l --git '--date=+%Y-%m-%d %H:%M:%S'"
alias l="ll --blocks=permission,size,date,name"
alias la="l -A"

alias c="code ."
alias yx="yarn dlx"

alias wsc='wt switch --create --execute=claude'

# removes the -v flag in the oh-my-zsh git plugin
alias gc="git commit"

# restore the run-help command (aliased to man for some reason)
unalias run-help
autoload run-help

# Initialize zsh completions
autoload -Uz compinit && compinit

# Add worktrunk shell integration
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# ---------------------------------------------------------------------------
# Auto-start tmux for SSH sessions
if [[ -z "$TMUX" ]] && [[ -n "$SSH_CONNECTION" ]]; then
  tmux attach-session -t remote || tmux new-session -s remote
fi
